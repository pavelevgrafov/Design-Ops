{
  "$schema": "https://design-tokens.org/schema/dtcg/2025-10",
  "$meta": { "name": "base-app", "description": "K2A base skin, app profile: dense work surface, calm and scannable. Applied automatically after Gate 1. Maintained as a flagship asset (contract tests on revision)." },
  "primitive": {
    "color": {
      "gray": {
        "50":  { "$value": "#fafaf9", "$type": "color" },
        "100": { "$value": "#f0efed", "$type": "color" },
        "200": { "$value": "#dddbd7", "$type": "color" },
        "300": { "$value": "#bfbcb6", "$type": "color" },
        "400": { "$value": "#8f8b85", "$type": "color" },
        "500": { "$value": "#6e6a64", "$type": "color" },
        "600": { "$value": "#4a4741", "$type": "color" },
        "700": { "$value": "#34322d", "$type": "color" },
        "800": { "$value": "#211f1c", "$type": "color" },
        "900": { "$value": "#141312", "$type": "color" }
      },
      "accent": {
        "300": { "$value": "#38b6cc", "$type": "color" },
        "500": { "$value": "#1697b0", "$type": "color" },
        "600": { "$value": "#0e7490", "$type": "color" },
        "700": { "$value": "#155e75", "$type": "color" }
      }
    },
    "font": {
      "family": {
        "display": { "$value": ["Public Sans", "system-ui", "sans-serif"], "$type": "fontFamily" },
        "text":    { "$value": ["Public Sans", "system-ui", "sans-serif"], "$type": "fontFamily" },
        "mono":    { "$value": ["IBM Plex Mono", "ui-monospace", "monospace"], "$type": "fontFamily" }
      },
      "scale": {
        "ratio":  { "$value": 1.25, "$type": "number" },
        "step-1": { "$value": "0.8rem",   "$type": "dimension" },
        "step0":  { "$value": "1rem",     "$type": "dimension" },
        "step1":  { "$value": "1.25rem",  "$type": "dimension" },
        "step2":  { "$value": "1.563rem", "$type": "dimension" },
        "step3":  { "$value": "1.953rem", "$type": "dimension" },
        "step4":  { "$value": "2.441rem", "$type": "dimension" },
        "step5":  { "$value": "3.052rem", "$type": "dimension" }
      },
      "lineHeight": {
        "tight": { "$value": 1.15, "$type": "number" },
        "body":  { "$value": 1.5, "$type": "number" },
        "loose": { "$value": 1.7, "$type": "number" }
      }
    },
    "space": {
      "1": { "$value": "0.25rem", "$type": "dimension" },
      "2": { "$value": "0.5rem",  "$type": "dimension" },
      "3": { "$value": "0.75rem", "$type": "dimension" },
      "4": { "$value": "1rem",    "$type": "dimension" },
      "6": { "$value": "1.5rem",  "$type": "dimension" },
      "8": { "$value": "2rem",    "$type": "dimension" },
      "12": { "$value": "3rem",   "$type": "dimension" },
      "16": { "$value": "4rem",   "$type": "dimension" },
      "24": { "$value": "6rem",   "$type": "dimension" }
    },
    "radius": {
      "sm": { "$value": "0.25rem", "$type": "dimension" },
      "md": { "$value": "0.5rem",  "$type": "dimension" },
      "lg": { "$value": "1rem",    "$type": "dimension" }
    }
  },
  "semantic": {
    "color": {
      "canvas":            { "$value": "{primitive.color.gray.50}",  "$type": "color" },
      "canvasRaised":      { "$value": "#ffffff",                    "$type": "color" },
      "ink":               { "$value": "{primitive.color.gray.900}", "$type": "color" },
      "inkMuted":          { "$value": "{primitive.color.gray.600}", "$type": "color" },
      "actionPrimary":     { "$value": "{primitive.color.accent.600}", "$type": "color" },
      "actionPrimaryText": { "$value": "#ffffff", "$type": "color" },
      "focusRing":         { "$value": "{primitive.color.accent.500}", "$type": "color" },
      "borderSubtle":      { "$value": "{primitive.color.gray.200}", "$type": "color" },
      "surfaceDark":       { "$value": "{primitive.color.gray.900}", "$type": "color" },
      "inkOnDark":         { "$value": "{primitive.color.gray.50}", "$type": "color" }
    },
    "font": {
      "body":    { "$value": "{primitive.font.family.text}",    "$type": "fontFamily" },
      "display": { "$value": "{primitive.font.family.display}", "$type": "fontFamily" }
    },
    "measure": {
      "body": { "$value": "65ch", "$type": "dimension" }
    }
  }
}
