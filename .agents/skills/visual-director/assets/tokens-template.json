{
  "$schema": "https://design-tokens.org/schema/dtcg/2025-10",
  "primitive": {
    "color": {
      "gray": {
        "50":  { "$value": "#f7f7f7", "$type": "color" },
        "100": { "$value": "#ececec", "$type": "color" },
        "200": { "$value": "#d9d9d9", "$type": "color" },
        "300": { "$value": "#bdbdbd", "$type": "color" },
        "400": { "$value": "#8f8f8f", "$type": "color" },
        "500": { "$value": "#6e6e6e", "$type": "color" },
        "600": { "$value": "#4a4a4a", "$type": "color" },
        "700": { "$value": "#333333", "$type": "color" },
        "800": { "$value": "#1f1f1f", "$type": "color" },
        "900": { "$value": "#111111", "$type": "color" }
      },
      "accent": {
        "comment": "Direction-specific ramp. Replace with the chosen direction's hue family. NEVER indigo→purple gradient endpoints.",
        "300": { "$value": "#000000", "$type": "color" },
        "500": { "$value": "#000000", "$type": "color" },
        "600": { "$value": "#000000", "$type": "color" },
        "700": { "$value": "#000000", "$type": "color" }
      }
    },
    "font": {
      "family": {
        "display": { "$value": ["{Display Family}", "system-ui", "sans-serif"], "$type": "fontFamily",
          "comment": "First position: the direction's display face. Ban-list fonts (Inter/Roboto/Arial/Space Grotesk) forbidden in first position. A generic fallback at the end is mandatory (D8)." },
        "text":    { "$value": ["{Text Family}", "system-ui", "sans-serif"], "$type": "fontFamily" },
        "mono":    { "$value": ["{Mono Family}", "ui-monospace", "monospace"], "$type": "fontFamily" }
      },
      "scale": {
        "comment": "Modular scale, ratio 1.2–1.333 (checked by check-typography.py as D7).",
        "ratio":  { "$value": 1.25, "$type": "number" },
        "step-1": { "$value": "0.8rem",   "$type": "dimension" },
        "step0":  { "$value": "1rem",     "$type": "dimension" },
        "step1":  { "$value": "1.25rem",  "$type": "dimension" },
        "step2":  { "$value": "1.563rem", "$type": "dimension" },
        "step3":  { "$value": "1.953rem", "$type": "dimension" },
        "step4":  { "$value": "2.441rem", "$type": "dimension" },
        "step5":  { "$value": "3.052rem", "$type": "dimension" }
      },
      "lineHeight": {
        "tight": { "$value": 1.2, "$type": "number" },
        "body":  { "$value": 1.55, "$type": "number", "comment": "must stay within 1.4–1.7 (D6)" },
        "loose": { "$value": 1.7, "$type": "number" }
      }
    },
    "space": {
      "1": { "$value": "0.25rem", "$type": "dimension" },
      "2": { "$value": "0.5rem",  "$type": "dimension" },
      "3": { "$value": "0.75rem", "$type": "dimension" },
      "4": { "$value": "1rem",    "$type": "dimension" },
      "6": { "$value": "1.5rem",  "$type": "dimension" },
      "8": { "$value": "2rem",    "$type": "dimension" },
      "12": { "$value": "3rem",   "$type": "dimension" },
      "16": { "$value": "4rem",   "$type": "dimension" },
      "24": { "$value": "6rem",   "$type": "dimension" }
    },
    "radius": {
      "sm": { "$value": "0.25rem", "$type": "dimension" },
      "md": { "$value": "0.5rem",  "$type": "dimension" },
      "lg": { "$value": "1rem",    "$type": "dimension" }
    }
  },
  "semantic": {
    "color": {
      "canvas":            { "$value": "{primitive.color.gray.50}",  "$type": "color" },
      "canvasRaised":      { "$value": "#ffffff",                    "$type": "color" },
      "ink":               { "$value": "{primitive.color.gray.900}", "$type": "color",
        "comment": "D3 pair ink/canvas must be ≥ 4.5:1" },
      "inkMuted":          { "$value": "{primitive.color.gray.600}", "$type": "color",
        "comment": "D3 pair inkMuted/canvas must be ≥ 4.5:1 — still body text" },
      "actionPrimary":     { "$value": "{primitive.color.accent.600}", "$type": "color" },
      "actionPrimaryText": { "$value": "#ffffff", "$type": "color",
        "comment": "D3 pair actionPrimaryText/actionPrimary ≥ 4.5:1" },
      "focusRing":         { "$value": "{primitive.color.accent.500}", "$type": "color" },
      "borderSubtle":      { "$value": "{primitive.color.gray.200}", "$type": "color" },
      "surfaceDark":       { "$value": "{primitive.color.gray.900}", "$type": "color" },
      "inkOnDark":         { "$value": "{primitive.color.gray.50}", "$type": "color" }
    },
    "font": {
      "body":    { "$value": "{primitive.font.family.text}",    "$type": "fontFamily" },
      "display": { "$value": "{primitive.font.family.display}", "$type": "fontFamily" }
    },
    "measure": {
      "body": { "$value": "65ch", "$type": "dimension", "comment": "D5: 45–75ch; on localization risk checked on both language variants" }
    }
  }
}
