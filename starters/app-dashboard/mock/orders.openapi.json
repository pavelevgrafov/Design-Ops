{
 "openapi": "3.0.3",
 "info": {
  "title": "Orders mock API",
  "version": "0.1.0"
 },
 "paths": {
  "/orders": {
   "get": {
    "summary": "list orders",
    "responses": {
     "200": {
      "description": "array of orders"
     }
    }
   }
  },
  "/orders/{id}": {
   "patch": {
    "summary": "update order status",
    "responses": {
     "200": {
      "description": "updated order"
     },
     "403": {
      "description": "permission denied (role)"
     }
    }
   }
  }
 }
}